<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <!-- ================================================================== -->
  <!-- Production (default): JSON to stdout — Loki scrapes stdout         -->
  <!-- ================================================================== -->
  <springProfile name="!dev">
    <appender class="ch.qos.logback.core.ConsoleAppender" name="STDOUT_JSON">
      <encoder class="org.ikigaidigital.adapter.in.rest.logging.MaskingJsonEncoder">
        <customFields>{"service":"time-deposit-api"}</customFields>
        <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
          <maxDepthPerThrowable>10</maxDepthPerThrowable>
          <rootCauseFirst>true</rootCauseFirst>
        </throwableConverter>
        <timeZone>UTC</timeZone>
        <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSS'Z'</timestampPattern>
      </encoder>
    </appender>

    <logger additivity="false" level="INFO" name="AUDIT">
      <appender-ref ref="STDOUT_JSON"/>
    </logger>

    <root level="INFO">
      <appender-ref ref="STDOUT_JSON"/>
    </root>
  </springProfile>

  <!-- ================================================================== -->
  <!-- Dev profile: human-readable console with correlationId             -->
  <!-- ================================================================== -->
  <springProfile name="dev">
    <appender class="ch.qos.logback.core.ConsoleAppender" name="STDOUT_CONSOLE">
      <layout class="org.ikigaidigital.adapter.in.rest.logging.MaskingPatternLayout">
        <pattern>%d{HH:mm:ss.SSS} [%thread] [%X{correlationId:-no-cid}] %-5level %logger{36} - %msg%n</pattern>
      </layout>
    </appender>

    <logger additivity="false" level="DEBUG" name="AUDIT">
      <appender-ref ref="STDOUT_CONSOLE"/>
    </logger>

    <root level="INFO">
      <appender-ref ref="STDOUT_CONSOLE"/>
    </root>
  </springProfile>

</configuration>
